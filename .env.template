STORE_CORS=http://localhost:8000,https://docs.medusajs.com
ADMIN_CORS=http://localhost:5173,http://localhost:9000,https://docs.medusajs.com
AUTH_CORS=http://localhost:5173,http://localhost:9000,https://docs.medusajs.com
REDIS_URL=redis://localhost:6379
JWT_SECRET=supersecret
COOKIE_SECRET=supersecret
DATABASE_URL=
DB_NAME=ta_strike_arena

# File storage — leave unset for local dev (uses @medusajs/file-local).
# Set all S3_* vars to switch to Cloudflare R2 (or any S3-compatible provider) in production.
S3_FILE_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto
S3_BUCKET=
S3_ENDPOINT=

# FluidPay payment gateway — leave FLUIDPAY_API_KEY unset to disable the provider.
# FLUIDPAY_API_KEY is the secret key (api_...) used server-side only.
# FLUIDPAY_PUBLIC_KEY is the public key (pub_...) passed through to the storefront
# for the Tokenizer iframe — safe to embed in client code.
# FLUIDPAY_BASE_URL defaults to sandbox; set to https://app.fluidpay.com for prod.
# FLUIDPAY_CAPTURE_MODE: "authorize" (default, capture later) or "sale" (capture immediately).
FLUIDPAY_API_KEY=
FLUIDPAY_PUBLIC_KEY=
FLUIDPAY_BASE_URL=https://sandbox.fluidpay.com
FLUIDPAY_CAPTURE_MODE=authorize

# Shippo live shipping rates + label purchase + tracking.
# Leave SHIPPO_API_KEY unset to fall back to manual flat rates ($10/$25).
# Sandbox keys start with shippo_test_, production keys with shippo_live_.
# SHIPPO_FROM_* is the warehouse origin address sent to carriers for rate
# quotes and printed on labels. All six *_ZIP / *_CITY etc. are required
# when the API key is set.
# SHIPPO_WEBHOOK_SECRET is the signing secret configured in Shippo dashboard
# → Settings → Webhooks. Used to verify X-Shippo-Signature on incoming
# webhook POSTs to /hooks/shippo.
SHIPPO_API_KEY=
SHIPPO_BASE_URL=
SHIPPO_FROM_NAME=Strike Arena Warehouse
SHIPPO_FROM_STREET1=
SHIPPO_FROM_STREET2=
SHIPPO_FROM_CITY=
SHIPPO_FROM_STATE=
SHIPPO_FROM_ZIP=
SHIPPO_FROM_COUNTRY=US
SHIPPO_FROM_PHONE=
SHIPPO_FROM_EMAIL=
SHIPPO_WEBHOOK_SECRET=

# TaxJar live sales-tax calculation + economic-nexus monitoring.
# Leave TAXJAR_API_KEY unset to fall back to the built-in "system" tax
# provider (zero rates, no tax charged). Sandbox and live tokens are
# separate; TAXJAR_SANDBOX defaults to true — set to "false" for prod.
# TAXJAR_FROM_* overrides the warehouse origin sent to TaxJar; when
# unset, falls back to the matching SHIPPO_FROM_* values.
TAXJAR_API_KEY=
TAXJAR_SANDBOX=true
TAXJAR_FROM_ZIP=
TAXJAR_FROM_STATE=
TAXJAR_FROM_CITY=
TAXJAR_FROM_STREET1=

# ── Dev reset flow (`npm run pull:prod` + `npm run reset`) ────
# These let `npm run reset` rebuild your local dev DB from a cached snapshot
# of production, scrubbing transactional/PII data and bootstrapping dev-only
# auth + procurement state. See `Resetting dev from prod` in CLAUDE.md.
#
# `npm run pull:prod` reads PROD_R2_* to mirror production images locally.
# These should be a READ-ONLY R2 token (Object Read only) — the script
# never writes to prod.
PROD_R2_ACCESS_KEY_ID=
PROD_R2_SECRET_ACCESS_KEY=
PROD_R2_BUCKET=ta-strike-arena-images
PROD_R2_ENDPOINT=
PROD_R2_PUBLIC_BASE=

# `npm run reset` re-injects these dev-specific creds after restoring the
# prod catalog. DEV_PUBLISHABLE_KEY must match the storefront's
# NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY in ta-strike-arena-website/.env.
DEV_ADMIN_EMAIL=admin@tacticalaffairs.com
DEV_ADMIN_PASSWORD=testing
DEV_PUBLISHABLE_KEY=
DEV_DEFAULT_STOCK=100

# Local Postgres container name. Used by:
#   - npm run reset (drops/recreates the dev DB through it)
#   - npm run pull:prod (uses it as the psql host for the SHOW server_version probe)
POSTGRES_CONTAINER=ta-strike-arena-postgres
POSTGRES_USER=medusa

# Railway service name for the prod Postgres database. `pull-prod.ts` reads
# DATABASE_PUBLIC_URL from this service to find the externally-reachable proxy
# hostname. Override only if you renamed the service in Railway.
RAILWAY_POSTGRES_SERVICE=Postgres
